{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MeshManager",
  "version": "0.1.1",
  "identifier": "com.emaspa.meshmanager",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MeshManager",
        "width": 1280,
        "height": 820,
        "minWidth": 940,
        "minHeight": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "category": "Utility",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/amtd"],
    "licenseFile": "../../LICENSE",
    "resources": {
      "../../LICENSE": "LICENSE",
      "../../NOTICE": "NOTICE",
      "../../THIRD_PARTY_NOTICES.md": "THIRD_PARTY_NOTICES.md"
    }
  }
}
